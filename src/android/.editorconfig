# EditorConfig for Piper Android SDK
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4

[*.xml]
indent_size = 4

[*.{gradle,gradle.kts}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.pro]
indent_size = 4

[*.{c,cpp,h,hpp}]
indent_size = 4

[*.toml]
indent_size = 4

[*.properties]
indent_size = 4

[*.bat]
end_of_line = crlf
