{
  "all": true,
  "include": [
    "src/**/*.js"
  ],
  "exclude": [
    "dist/**",
    "node_modules/**",
    "test/**",
    "scripts/**",
    "types/**",
    "build/**",
    "demo/**",
    "coverage/**",
    "**/*.cpp",
    "src/audio-worklet-processor.js"
  ],
  "reporter": [
    "lcov",
    "text"
  ],
  "report-dir": "coverage",
  "check-coverage": false,
  "skip-full": false
}
