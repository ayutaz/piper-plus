root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,ts,jsx,tsx,json,yml,yaml}]
indent_size = 2

[*.{rs,toml}]
indent_size = 4

[*.py]
# multi-line function-call の continuation indent (opening-paren alignment)
# は ruff format が canonical で 4 の倍数にならないケースがある (例:
# `def f(\n    a,\n     b,)` のような visual alignment)。editorconfig-checker
# の "indent must be multiple of N" 検査は ruff format と衝突するので Python に
# 関しては `indent_size = unset` で off にし、format strictness は ruff に委ねる
# (CI / pre-commit が canonical formatter)。
indent_size = unset

[*.go]
indent_style = tab
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
# Markdown は仕様上 2-space indent の continuation を多用する (CommonMark `### List`
# の継続段落、blockquote 内の lists 等)。global 4-space ルールを適用すると 11 言語
# README + CHANGELOG / docs/spec で広範な既存 drift が検出されるため、markdown
# のみ indent multiple check を免除する。実際の lint は markdownlint-cli2 が担当。
indent_size = unset

[Makefile]
indent_style = tab

# The legacy C++ runtime (piper.cpp / piper.hpp / main.cpp / ssml.cpp /
# ssml.hpp) uses 2-space indentation plus arbitrary column-alignment spaces
# (1/3/5-wide) for continuation lines and parameter lists. The "indent must
# be a multiple of N" check is not meaningful for this style, so disable it
# for these files only.
[src/cpp/{piper.cpp,piper.hpp,main.cpp,ssml.cpp,ssml.hpp}]
indent_size = unset

# rustfmt aligns continuation lines inside multi-line string literals to
# the opening quote column (not a power-of-2 indent). engine.rs uses this
# pattern liberally in error messages; the indent-multiple check fights
# the formatter, so opt out for this file only.
[src/rust/piper-core/src/engine.rs]
indent_size = unset

# Issue #426 integration tests link the legacy piper.cpp / engine.rs
# runtime code paths and share their rustfmt / clang-format column-
# alignment style. Same opt-out as the legacy files.
[src/rust/piper-core/tests/test_speaker_embedding_integration.rs]
indent_size = unset

[src/cpp/tests/test_speaker_embedding_inference.cpp]
indent_size = unset

# SSML parser tests follow the legacy src/cpp 2-space indent style to match
# ssml.hpp / ssml.cpp (whose own opt-out is grouped with piper.cpp above).
[src/cpp/tests/test_ssml.cpp]
indent_size = unset

# Short-text mitigation tests follow the legacy src/cpp 2-space indent style
# to match piper.cpp (whose own opt-out is grouped with piper.cpp above). The
# test file replicates piper.cpp's trim helpers verbatim so the indentation
# style must match.
[src/cpp/tests/test_short_text_mitigation.cpp]
indent_size = unset

# Cross-runtime contract specs in docs/spec/ use column-alignment for
# inline `# comment` annotations (e.g. `sample_rate = 22050        # Hz`),
# array entries with inline tables, and field tables with aligned widths
# (audio-format-contract.toml field_order, ort-provider-contract.toml
# auto_detect_priority, etc.). The indent-multiple-of-4 check fights the
# readability of these tables, so the entire spec dir opts out.
[docs/spec/*.toml]
indent_size = unset

# CMake files in this repo are written with 2-space indentation (matching
# the legacy piper.cpp/.hpp style imported from the upstream piper project).
# MSBuild project files (.csproj) also use 2-space indentation per
# Visual Studio defaults. Opt these in explicitly so the
# indent-multiple-of-4 check from [*] does not fire.
[*.cmake]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

[*.csproj]
indent_size = unset

# registry.py's module-level docstring uses 3-space ReST literal-block
# indentation under numbered list items (PEP 257 / Sphinx convention),
# which is incompatible with the indent-multiple-of-4 check. The actual
# Python code in this file follows 4-space indentation.
[src/python/g2p/piper_plus_g2p/registry.py]
indent_size = unset

# Contract-gate scripts use ReST bullet/numbered-list continuation
# indentation (2-space follow-on) inside module-level docstrings, which
# fights the indent-multiple-of-4 check. The actual Python code in these
# scripts follows 4-space indentation.
[scripts/check_*.py]
indent_size = unset

# android-build.yml and swift-g2p-ci.yml use shell line-continuation column
# alignment (15-/17-space indent for `\`-continued bash arguments and case
# branch continuations) inside `run:` blocks. yamllint is fine with this
# since YAML treats the block-literal contents as opaque text, but the
# indent-multiple-of-2 check fights the continuation style.
[.github/workflows/android-build.yml]
indent_size = unset

[.github/workflows/swift-g2p-ci.yml]
indent_size = unset
