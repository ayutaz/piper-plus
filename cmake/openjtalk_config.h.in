/* config.h for OpenJTalk on Windows */

#ifndef CONFIG_H
#define CONFIG_H

/* Define to 1 if you have the <dlfcn.h> header file. */
#cmakedefine HAVE_DLFCN_H 1

/* Define to 1 if you have the <fcntl.h> header file. */
#define HAVE_FCNTL_H 1

/* Define to 1 if you have the <inttypes.h> header file. */
#define HAVE_INTTYPES_H 1

/* Define to 1 if you have the <memory.h> header file. */
#define HAVE_MEMORY_H 1

/* Define to 1 if you have the <stdint.h> header file. */
#define HAVE_STDINT_H 1

/* Define to 1 if you have the <stdlib.h> header file. */
#define HAVE_STDLIB_H 1

/* Define to 1 if you have the <strings.h> header file. */
#cmakedefine HAVE_STRINGS_H 1

/* Define to 1 if you have the <string.h> header file. */
#define HAVE_STRING_H 1

/* Define to 1 if you have the <sys/stat.h> header file. */
#define HAVE_SYS_STAT_H 1

/* Define to 1 if you have the <sys/types.h> header file. */
#define HAVE_SYS_TYPES_H 1

/* Define to 1 if you have the <unistd.h> header file. */
#cmakedefine HAVE_UNISTD_H 1

/* Define to 1 if you have the `getpagesize' function. */
#cmakedefine HAVE_GETPAGESIZE 1

/* Define to 1 if you have the `mmap' function. */
#cmakedefine HAVE_MMAP 1

/* Define to 1 if you have the `getenv' function. */
#define HAVE_GETENV 1

/* Define to 1 if you have the `opendir' function. */
#cmakedefine HAVE_OPENDIR 1

/* Define to 1 if the system has the type `size_t'. */
#define HAVE_SIZE_T 1

/* Name of package */
#define PACKAGE "open_jtalk"

/* Define to the address where bug reports for this package should be sent. */
#define PACKAGE_BUGREPORT ""

/* Define to the full name of this package. */
#define PACKAGE_NAME "open_jtalk"

/* Define to the full name and version of this package. */
#define PACKAGE_STRING "open_jtalk @OPENJTALK_VERSION@"

/* Define to the one symbol short name of this package. */
#define PACKAGE_TARNAME "open_jtalk"

/* Define to the version of this package. */
#define PACKAGE_VERSION "@OPENJTALK_VERSION@"

/* Version number of package */
#define VERSION "@OPENJTALK_VERSION@"

/* Define to `unsigned int' if <sys/types.h> does not define. */
/* #undef size_t */

/* MeCab configurations */
#define MECAB_DEFAULT_RC "dummy"
#define DIC_VERSION 102
#define CHAR_PROPERTY_DEF_DEFAULT ""
#define CHAR_PROPERTY_DEF_LOCATION ""
#define UNK_DEF_DEFAULT ""
#define UNK_DEF_LOCATION ""
#define DIC_FILE_LOCATION ""
#define MATRIX_DEF_DEFAULT ""
#define MATRIX_DEF_LOCATION ""
#define MECAB_USE_UTF8_ONLY 1
#define MECAB_DEFAULT_CHARSET "UTF-8"

/* Windows specific */
#ifdef _WIN32
#define WIN32_LEAN_AND_MEAN
#define NOMINMAX
#ifndef _CRT_SECURE_NO_WARNINGS
#define _CRT_SECURE_NO_WARNINGS
#endif
#endif

#endif /* CONFIG_H */