<?xml version="1.0" encoding="utf-8"?>
<!--
  Required for DictionaryDownloader.downloadFromHuggingFace() (M6).
  The library merges this permission into consuming apps via manifest merger;
  apps that only use bundled assets / fromPath() should still declare it.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
