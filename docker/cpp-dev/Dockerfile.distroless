# C++ dev environment (Wolfi-based minimal variant — trial).
#
# Trial variant of docker/cpp-dev/Dockerfile that swaps the ubuntu:24.04
# baseline for cgr.dev/chainguard/wolfi-base. The original Dockerfile
# stays UNCHANGED so:
#   * cpp-dev's interactive workflow (docker exec -it ... bash) keeps
#     working off the canonical tag while reviewers compare.
#   * docker-compose / CI matrices already pinned on the canonical
#     image don't break.
#   * Promotion to canonical is a follow-up PR after the trial confirms
#     dev experience parity.
#
# Why Wolfi (vs. gcr.io/distroless/cc-debian12):
#   * cpp-dev's purpose is interactive C++ work. distroless/cc has no
#     shell and no package manager, so `docker exec ... bash` and
#     `apt-get update && apt-get install -y <tool>` ad-hoc are both
#     impossible. That contradicts the image's role.
#   * Wolfi keeps a BusyBox shell + apk add, but stays minimal: it
#     ships glibc + the bare userland, leaving 90 %+ of Debian's
#     stock packages out of the SBOM. CVE surface shrinks while dev
#     ergonomics survive.
#   * Both the original M3 ticket and the broader proposal recommend
#     Wolfi specifically for dev images — see ticket §2.2.
#
# Build (from project root):
#   docker buildx build \
#     --platform linux/amd64,linux/arm64 \
#     -f docker/cpp-dev/Dockerfile.distroless \
#     -t piper-plus-cpp-dev:distroless-trial \
#     .
#
# Interactive use:
#   docker run --rm -it \
#     -v $PWD:/workspace \
#     piper-plus-cpp-dev:distroless-trial \
#     /bin/sh   # Wolfi ships BusyBox sh, not bash, by default

FROM cgr.dev/chainguard/wolfi-base

# Wolfi defaults to root for image build; the canonical Dockerfile drops
# to UID 1000 after install steps. We keep the same end state for parity
# with build.sh / test.sh which expect /workspace to be owned by piper.
USER root

# apk add the dev toolchain. apk's `--no-cache` keeps the image lean
# (no /var/cache/apk/ leftovers) and skips writing the package DB to
# disk on top of what's strictly needed. Pinning is opt-in — Wolfi
# rebuilds packages constantly and pinning would invite stale CVE,
# matching ticket DL3008 ignore rationale.
#
# Dev tool selection mirrors the canonical Dockerfile minus anything
# only useful for downloading the ONNX Runtime tarball at image-build
# time (curl / wget): those are temporary and can be installed
# on-demand by the user inside the running container.
RUN apk add --no-cache \
        bash \
        binutils \
        build-base \
        ca-certificates \
        clang \
        clang-extras \
        cmake \
        eigen-dev \
        fmt-dev \
        gdb \
        git \
        libsndfile-dev \
        ninja \
        openblas-dev \
        pkgconf \
        python-3.12 \
        spdlog-dev \
        valgrind

# ONNX Runtime CPU build, fetched from the canonical upstream release.
# Pin matches docker/cpp-dev/Dockerfile (canonical) — keep the two
# Dockerfiles in lockstep so dev experience between them is identical.
#
# Use the `arch` test to download the correct tarball: ONNX Runtime
# publishes -linux-x64 (amd64) and -linux-aarch64 (arm64) under the
# same release. The canonical Dockerfile only downloaded -linux-x64
# because it built on amd64 only — we extend to arm64 here.
RUN set -eux; \
    arch=$(uname -m); \
    case "$arch" in \
      x86_64)  ort_arch=x64 ;; \
      aarch64) ort_arch=aarch64 ;; \
      *)       echo "unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    wget -qO /tmp/onnxruntime.tgz \
      "https://github.com/microsoft/onnxruntime/releases/download/v1.20.0/onnxruntime-linux-${ort_arch}-1.20.0.tgz"; \
    mkdir -p /tmp/ort; \
    tar -xzf /tmp/onnxruntime.tgz -C /tmp/ort --strip-components=1; \
    cp -r /tmp/ort/lib/* /usr/local/lib/; \
    cp -r /tmp/ort/include/* /usr/local/include/; \
    ldconfig 2>/dev/null || /usr/sbin/ldconfig 2>/dev/null || true; \
    rm -rf /tmp/ort /tmp/onnxruntime.tgz

# OpenJTalk + HTS Engine source build. Wolfi doesn't ship these as
# prebuilt apk packages (they're not common enough), so we fall back
# to the canonical Dockerfile's source-install path.
#
# `make -j1` for Open JTalk because its build graph has a documented
# race condition with parallel make — the canonical Dockerfile
# already pins j=1 for this reason.
RUN set -eux; \
    wget -qO /tmp/hts.tar.gz https://downloads.sourceforge.net/hts-engine/hts_engine_API-1.10.tar.gz; \
    tar -xzf /tmp/hts.tar.gz -C /tmp; \
    cd /tmp/hts_engine_API-1.10; \
    ./configure --prefix=/usr/local; \
    make -j"$(nproc)"; \
    make install; \
    rm -rf /tmp/hts*

RUN set -eux; \
    wget -qO /tmp/oj.tar.gz https://downloads.sourceforge.net/open-jtalk/open_jtalk-1.11.tar.gz; \
    tar -xzf /tmp/oj.tar.gz -C /tmp; \
    cd /tmp/open_jtalk-1.11; \
    ./configure --prefix=/usr/local \
        --with-hts-engine-header-path=/usr/local/include \
        --with-hts-engine-library-path=/usr/local/lib; \
    make -j1; \
    make install; \
    rm -rf /tmp/open_jtalk* /tmp/oj.tar.gz

# uv via official installer (matches canonical). Wolfi's adduser /
# group tooling is BusyBox-flavoured but compatible with the canonical
# `useradd -m -u 1000 piper` calls — translate to apk's `adduser`.
ENV UV_INSTALL_DIR=/usr/local/bin
ADD https://astral.sh/uv/install.sh /uv-installer.sh
RUN sh /uv-installer.sh && rm /uv-installer.sh

ENV VIRTUAL_ENV=/opt/devtools
RUN uv venv "$VIRTUAL_ENV"
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

RUN uv pip install \
        conan \
        cpplint \
        cppcheck \
        cmake-format \
        gcovr

# Workspace + non-root user. Wolfi's BusyBox `adduser -D` creates a
# system user without prompting for a password; the canonical Ubuntu
# Dockerfile uses `useradd -m -u 1000`. The end state — UID 1000
# owning /workspace — matches.
RUN adduser -D -u 1000 piper && \
    mkdir -p /workspace/build /workspace/.ccache && \
    chown -R piper:piper /workspace /opt/devtools

COPY docker/cpp-dev/build.sh /workspace/build.sh
COPY docker/cpp-dev/test.sh /workspace/test.sh
RUN chmod +x /workspace/build.sh /workspace/test.sh && \
    chown piper:piper /workspace/build.sh /workspace/test.sh

# Verify the dev toolchain on image build. If any of these fail, the
# image is non-functional and we want to know during CI rather than
# the first developer pull.
RUN set -eux; \
    cmake --version; \
    clang --version; \
    gdb --version | head -n1; \
    python3 --version; \
    test -f /usr/local/lib/libonnxruntime.so; \
    test -d /usr/local/share/open_jtalk || test -f /usr/local/bin/open_jtalk

USER piper
WORKDIR /workspace

CMD ["echo", "Container started successfully"]
