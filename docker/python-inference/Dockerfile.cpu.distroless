# CPU-only Python Inference image (distroless trial).
#
# Trial variant of docker/python-inference/Dockerfile.cpu that swaps the
# python:3.11-slim-trixie base for a multi-stage build whose final layer
# is cgr.dev/chainguard/python:latest (Wolfi-based, minimal, no shell,
# no package manager, no docs / man / locale). The existing
# `Dockerfile.cpu` (debian-slim) is intentionally left UNCHANGED so the
# trial does not break the docker-compose flow, the HF Space deploy
# pipeline, or the multi-arch buildx matrix already proven on it.
#
# Why a separate file:
#   * Side-by-side image build lets us A/B compare size + CVE counts.
#   * Promotion to the canonical image is a follow-up PR after staging
#     verification (HF Space cold start, ARM64 deploy).
#   * Roll-back is `git revert` of the trial PR — no compose/CD changes.
#
# Build (multi-arch, from repo root):
#   docker buildx build \
#     --platform linux/amd64,linux/arm64 \
#     -f docker/python-inference/Dockerfile.cpu.distroless \
#     -t piper-plus-inference:cpu-distroless-trial \
#     .
#
# Smoke (single-arch local):
#   docker build \
#     -f docker/python-inference/Dockerfile.cpu.distroless \
#     -t piper-plus-inference:cpu-distroless-trial \
#     .
#   docker run --rm -p 8000:8000 piper-plus-inference:cpu-distroless-trial \
#     /app/inference.py --help

# ----------------------------------------------------------------------
# Stage 1: builder (Debian-based, has apt/pip/build-essential).
# ----------------------------------------------------------------------
FROM python:3.13-slim-trixie AS builder

ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive

# build-essential / cmake / g++ are required because pyopenjtalk-plus
# (a transitive dep of piper-plus-g2p via the [all] extra) builds C
# extensions from source on arm64. libsndfile1-dev provides the .so /
# headers that soundfile needs at install AND runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    g++ \
    libsndfile1 \
    libsndfile1-dev \
    && rm -rf /var/lib/apt/lists/*

# Pin uv to the same major version range used by the canonical
# Dockerfile.cpu — workspace-editable handling is uv-version sensitive.
RUN pip install --no-cache-dir "uv>=0.9,<1"

WORKDIR /build

# Copy source for piper_plus_g2p + piper_train install. setup.py reads
# ../../VERSION relative to src/python/, so VERSION must be at
# /build/VERSION.
COPY VERSION /build/VERSION
COPY pyproject.toml /build/pyproject.toml
COPY src/python/ /build/src/python/
COPY src/python_run/requirements_webui.txt /build/requirements_webui.txt

# Install into the system Python so the layout under /usr/local/lib is
# self-contained and copy-able into the final stage.
RUN uv pip install --system "/build/src/python/g2p[all]"
RUN uv pip install --system "/build/src/python[inference]"
RUN uv pip install --system -r /build/requirements_webui.txt

# Pre-download NLTK data for g2p-en. The download dir is shared so the
# distroless final stage can read it post-USER-switch.
ENV NLTK_DATA=/usr/share/nltk_data
RUN python -c "import nltk; \
nltk.download('averaged_perceptron_tagger', download_dir='/usr/share/nltk_data'); \
nltk.download('averaged_perceptron_tagger_eng', download_dir='/usr/share/nltk_data'); \
nltk.download('cmudict', download_dir='/usr/share/nltk_data')"

# Builder-side smoke test. If onnxruntime / piper_train / gradio fail to
# import here, the final stage won't be runnable either — fail fast.
RUN python --version && \
    python -c "import platform; print(f'builder arch: {platform.machine()}')" && \
    python -c "import onnxruntime as ort; print(f'ONNX Runtime: {ort.__version__}'); print(f'Providers: {ort.get_available_providers()}')" && \
    python -c "import piper_train; print('piper_train OK')" && \
    python -c "import gradio; print(f'Gradio: {gradio.__version__}')" && \
    python -c "import fastapi, uvicorn; print(f'FastAPI: {fastapi.__version__}, uvicorn: {uvicorn.__version__}')"

# ----------------------------------------------------------------------
# Stage 2: distroless final.
# ----------------------------------------------------------------------
# cgr.dev/chainguard/python is Wolfi-based, ships only python3 + libc +
# CA certificates. No shell, no package manager, no man / docs / locale.
# Tag `latest` follows the most-recent Python minor; in CI we still
# want a reproducible build, so the workflow pins via `--build-arg`
# overridable digest.
FROM cgr.dev/chainguard/python:latest

# Bring in the platform-specific runtime shared libs. soundfile (used by
# piper_train) dlopen()s libsndfile; onnxruntime CPU EP dlopen()s libgomp.
# Both have to follow the python site-packages we copy below.
#
# The chainguard/python base lays out /usr/lib (Wolfi root); shared libs
# we COPY here need to land where the dynamic loader looks, so we mirror
# the builder's debian layout under /usr/lib/$(arch)-linux-gnu/ and the
# loader resolves them via ld.so default search path.
COPY --from=builder /usr/lib/*-linux-gnu/libsndfile.so* /usr/lib/
COPY --from=builder /usr/lib/*-linux-gnu/libgomp.so* /usr/lib/
COPY --from=builder /usr/lib/*-linux-gnu/libFLAC.so* /usr/lib/
COPY --from=builder /usr/lib/*-linux-gnu/libvorbis.so* /usr/lib/
COPY --from=builder /usr/lib/*-linux-gnu/libvorbisenc.so* /usr/lib/
COPY --from=builder /usr/lib/*-linux-gnu/libogg.so* /usr/lib/
COPY --from=builder /usr/lib/*-linux-gnu/libopus.so* /usr/lib/
COPY --from=builder /usr/lib/*-linux-gnu/libmpg123.so* /usr/lib/

# Python site-packages and CLI entry-points. The builder Python is 3.13;
# chainguard/python:latest also tracks 3.13, so paths match. If the
# minor versions diverge (chainguard moves to 3.14 before we update),
# the build smoke step below catches it.
COPY --from=builder /usr/local/lib/python3.13 /usr/local/lib/python3.13
COPY --from=builder /usr/local/bin/uvicorn /usr/local/bin/uvicorn
COPY --from=builder /usr/share/nltk_data /usr/share/nltk_data

# Python site-packages must be importable. chainguard/python ships its
# own python at /usr/bin/python3; we point sys.path at the builder
# install via PYTHONPATH so the final image's interpreter sees them.
ENV PYTHONPATH=/usr/local/lib/python3.13/site-packages
ENV NLTK_DATA=/usr/share/nltk_data
ENV PYTHONUNBUFFERED=1
ENV GRADIO_SERVER_NAME=0.0.0.0
ENV GRADIO_SERVER_PORT=7860

# Inference + WebUI scripts. /app is writable by the default chainguard
# nonroot user (UID 65532).
COPY docker/python-inference/inference.py /app/inference.py
COPY docker/python-inference/test.py /app/test.py
COPY docker/webui/app.py /app/webui.py

WORKDIR /app

EXPOSE 8000 7860

# chainguard/python:latest defaults to nonroot user (UID 65532). No
# `USER` directive needed; documenting the assumption for reviewers.

# distroless has no shell — HEALTHCHECK must be exec-form, and inline
# python. Using urllib (stdlib) keeps the check binary-free.
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD ["python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"]

# Default entrypoint matches Dockerfile.cpu — OpenAI-compat FastAPI
# server bound to 8000. Override at `docker run` for CLI / WebUI modes.
ENTRYPOINT ["python", "/app/inference.py"]
CMD ["--server", "--model", "/app/models/model.onnx", "--port", "8000"]
